{
  "installCommand": "npm i -g pnpm@10 && pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/localstore run build",
  "outputDirectory": "artifacts/localstore/dist/public",
  "framework": null,
  "functions": {
    "api/server.ts": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server" }
  ],
  "env": {
    "BASE_PATH": "/",
    "VERCEL": "1"
  }
}
